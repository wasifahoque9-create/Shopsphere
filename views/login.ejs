<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — AuthKit</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="auth-card">

    <div class="auth-logo">
      <svg width="30" height="30" viewBox="0 0 30 30" fill="none">
        <rect width="30" height="30" rx="7"/>
        <path d="M15 7l9 5v6l-9 5-9-5v-6l9-5z" stroke="white" stroke-width="1.5" fill="none"/>
        <circle cx="15" cy="15" r="3.5" fill="white"/>
      </svg>
      <span class="auth-logo-name">AuthKit</span>
    </div>

    <div class="auth-header">
      <h2>Sign in to your account</h2>
      <p>Enter your credentials below</p>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">✓ <%= success[0] %></div>
    <% } %>

    <% if (error && error.length > 0) { %>
      <div class="alert alert-error">⚠ <%= error[0] %></div>
    <% } %>

    <form action="/login" method="POST" class="auth-form" novalidate>

      <div class="field-group">
        <label for="email">Email address</label>
        <div class="input-wrap">
          <input
            type="email"
            id="email"
            name="email"
            placeholder="you@example.com"
            value="<%= old.email || '' %>"
            required
            autocomplete="email"
          />
        </div>
      </div>

      <div class="field-group">
        <label for="password">Password</label>
        <div class="input-wrap">
          <input
            type="password"
            id="password"
            name="password"
            placeholder="Enter your password"
            required
            autocomplete="current-password"
          />
          <button type="button" class="toggle-pw" onclick="togglePassword('password', this)" title="Show password">
            <svg width="17" height="17" viewBox="0 0 18 18" fill="none"><ellipse cx="9" cy="9" rx="7" ry="4.5" stroke="currentColor" stroke-width="1.4"/><circle cx="9" cy="9" r="2" fill="currentColor"/></svg>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-primary">Sign in</button>
    </form>

    <hr class="divider" />

    <p class="form-footer">
      Don't have an account? <a href="/register">Create one</a>
    </p>

  </div>
  <script src="/js/app.js"></script>
</body>
</html>
