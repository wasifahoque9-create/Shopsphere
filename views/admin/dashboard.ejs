<%- include('layout-top') %>

    <div class="admin-header">
      <div>
        <h1>Dashboard</h1>
        <p class="admin-subtitle">Welcome back, <%= admin.name %>. Here's what's happening.</p>
      </div>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">✓ <%= success[0] %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error">⚠ <%= error[0] %></div>
    <% } %>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon" style="background:#ede9fe; color:#6d28d9;">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><circle cx="8" cy="7" r="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M2 18c0-3.866 2.686-7 6-7s6 3.134 6 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M16 9v6M19 12h-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div>
          <p class="stat-label">Total Users</p>
          <p class="stat-value"><%= stats.totalUsers %></p>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background:#ecfdf5; color:#059669;">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><path d="M4 12l5 5L18 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div>
          <p class="stat-label">New This Week</p>
          <p class="stat-value"><%= stats.recentSignups %></p>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background:#fef3c7; color:#d97706;">
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none"><rect x="3" y="11" width="16" height="8" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M8 11V8a3 3 0 016 0v3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </div>
        <div>
          <p class="stat-label">Admins</p>
          <p class="stat-value"><%= stats.totalAdmins %></p>
        </div>
      </div>
    </div>

    <div class="table-card">
      <div class="table-header">
        <h2>Recent Users</h2>
        <a href="/admin/users" class="btn-outline">View all</a>
      </div>

      <% const recent = users.slice(-5).reverse(); %>
      <% if (recent.length === 0) { %>
        <div class="empty-state">No users registered yet.</div>
      <% } else { %>
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Joined</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            <% recent.forEach(user => { %>
              <tr>
                <td class="td-id">#<%= user.id.toString().padStart(4,'0') %></td>
                <td>
                  <div class="user-cell">
                    <div class="avatar-xs"><%= user.name.charAt(0).toUpperCase() %></div>
                    <%= user.name %>
                  </div>
                </td>
                <td class="td-muted"><%= user.email %></td>
                <td class="td-muted"><%= new Date(user.created_at).toLocaleDateString('en-GB') %></td>
                <td>
                  <form action="/admin/users/delete/<%= user.id %>" method="POST" onsubmit="return confirm('Delete <%= user.name %>?')">
                    <button type="submit" class="btn-danger-sm">Delete</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

  </div>
</body>
</html>
