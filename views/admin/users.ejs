<%- include('layout-top') %>

    <div class="admin-header">
      <div>
        <h1>Manage Users</h1>
        <p class="admin-subtitle">View, search, and manage all registered users.</p>
      </div>
      <a href="/admin/users/add" class="btn-primary-sm">+ Add User</a>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">✓ <%= success[0] %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="alert alert-error">⚠ <%= error[0] %></div>
    <% } %>

    <!-- Search -->
    <form action="/admin/users" method="GET" class="search-bar">
      <input
        type="text"
        name="search"
        placeholder="Search by name or email..."
        value="<%= search %>"
        class="search-input"
      />
      <button type="submit" class="btn-primary-sm">Search</button>
      <% if (search) { %>
        <a href="/admin/users" class="btn-outline">Clear</a>
      <% } %>
    </form>

    <div class="table-card">
      <% if (users.length === 0) { %>
        <div class="empty-state">
          <% if (search) { %>
            No users found matching "<%= search %>".
          <% } else { %>
            No users registered yet. <a href="/admin/users/add">Add one</a>.
          <% } %>
        </div>
      <% } else { %>
        <table class="data-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Joined</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(user => { %>
              <tr>
                <td class="td-id">#<%= user.id.toString().padStart(4,'0') %></td>
                <td>
                  <div class="user-cell">
                    <div class="avatar-xs"><%= user.name.charAt(0).toUpperCase() %></div>
                    <%= user.name %>
                  </div>
                </td>
                <td class="td-muted"><%= user.email %></td>
                <td>
                  <span class="role-badge role-<%= user.role %>"><%= user.role %></span>
                </td>
                <td class="td-muted"><%= new Date(user.created_at).toLocaleDateString('en-GB') %></td>
                <td>
                  <div class="action-row">
                    <form action="/admin/users/toggle-role/<%= user.id %>" method="POST">
                      <button type="submit" class="btn-outline-sm" title="Toggle role">
                        <%= user.role === 'user' ? 'Make Admin' : 'Make User' %>
                      </button>
                    </form>
                    <form action="/admin/users/delete/<%= user.id %>" method="POST" onsubmit="return confirm('Delete user <%= user.name %>? This cannot be undone.')">
                      <button type="submit" class="btn-danger-sm">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        <div class="table-footer"><%= users.length %> user(s) found</div>
      <% } %>
    </div>

  </div>
</body>
</html>
